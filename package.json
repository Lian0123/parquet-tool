{
  "name": "parquet-tool",
  "version": "1.0.0",
  "description": "Parquet file processing tool with C++ native addon — read, write, append, split and parallel process Parquet files",
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "bin": {
    "parquet-tool": "dist/cli/index.js"
  },
  "scripts": {
    "build": "npm run build:native && npm run build:ts",
    "build:ts": "tsc -p tsconfig.build.json",
    "build:native": "cmake-js compile",
    "rebuild": "cmake-js rebuild",
    "test": "jest --forceExit",
    "lint": "eslint 'src/**/*.ts'",
    "cz": "cz",
    "release": "NODE_OPTIONS='--require ./scripts/marked-compat.cjs' semantic-release",
    "release:dry-run": "npm run release -- --dry-run",
    "release:local": "npm run release -- --no-ci",
    "clean": "rm -rf dist build",
    "prepare": "husky",
    "prepublishOnly": "npm run build",
    "cli": "node dist/cli/index.js",
    "ci": "npm ci && npm run build && npm run lint && npm test",
    "ci:release": "npm run ci && npm run release"
  },
  "dependencies": {
    "apache-arrow": "^17.0.0",
    "commander": "^12.1.0",
    "csv-parse": "^5.5.6",
    "csv-stringify": "^6.5.2",
    "node-addon-api": "^8.3.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.0",
    "@typescript-eslint/eslint-plugin": "^6.1.0",
    "@typescript-eslint/parser": "^6.1.0",
    "cmake-js": "^7.3.0",
    "commitizen": "^4.2.5",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.39.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "marked-mangle": "^1.1.12",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  },
  "files": [
    "dist/",
    "src/native/",
    "CMakeLists.txt"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "license": "MIT"
}
