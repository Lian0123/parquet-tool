{
  "name": "parquet-tool",
  "version": "1.0.0",
  "description": "Parquet file processing tool with C++ native addon — read, write, append, split and parallel process Parquet files",
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "bin": {
    "parquet-tool": "dist/cli/index.js"
  },
  "scripts": {
    "build": "npm run build:native && npm run build:ts",
    "build:ts": "tsc -p tsconfig.build.json",
    "build:native": "cmake-js compile",
    "rebuild": "cmake-js rebuild",
    "test": "jest --forceExit",
    "lint": "eslint 'src/**/*.ts'",
    "cz": "cz",
    "release": "semantic-release",
    "clean": "rm -rf dist build",
    "prepublishOnly": "npm run build",
    "cli": "node dist/cli/index.js"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "node-addon-api": "^8.3.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.1.0",
    "@typescript-eslint/parser": "^6.1.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.0",
    "cmake-js": "^7.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "commitizen": "^4.2.5",
    "eslint": "^8.39.0",
    "jest": "^29.7.0",
    "semantic-release": "^21.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  },
  "files": [
    "dist/",
    "src/native/",
    "CMakeLists.txt"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "license": "MIT"
}
