
#!/bin/sh

# Skip in CI or when explicitly disabled.
if [ -n "$CI" ] || [ "$HUSKY" = "0" ]; then
	exit 0
fi

# Skip when commit message is already provided (e.g. git commit -m by bots).
if [ "$2" = "message" ]; then
	exit 0
fi

# Skip merge/squash commits and environments without commitizen installed.
if [ "$2" = "merge" ] || [ "$2" = "squash" ] || [ ! -x "./node_modules/.bin/cz" ]; then
	exit 0
fi

# Only prompt for new commit messages; do not overwrite existing message content.
if [ -s "$1" ]; then
	exit 0
fi

# Prefer using the controlling TTY for interactive prompts.
if [ -e /dev/tty ]; then
	exec < /dev/tty
fi

if [ -t 0 ] || [ -t 1 ]; then
	./node_modules/.bin/cz --hook || true
fi
