#!/bin/sh

# Skip in CI or when explicitly disabled.
if [ -n "$CI" ] || [ "$HUSKY" = "0" ]; then
	exit 0
fi

# Only run for normal interactive commits (source is empty).
if [ -n "$2" ]; then
	exit 0
fi

if [ ! -x "./node_modules/.bin/cz" ]; then
	exit 0
fi

# Prefer using the controlling TTY for interactive prompts.
if [ -e /dev/tty ]; then
	exec < /dev/tty
fi

if [ -t 0 ] || [ -t 1 ]; then
	./node_modules/.bin/cz --hook || true
fi
