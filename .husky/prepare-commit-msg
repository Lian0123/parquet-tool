
#!/bin/sh

# Git passes "message" as $2 when commit message is provided with -m.
# semantic-release uses `git commit -m`, so skip cz hook in that case.
if [ "$2" = "message" ]; then
	exit 0
fi

# Non-interactive environments (CI, release bots) do not have /dev/tty.
if [ -n "$CI" ] || [ ! -t 0 ]; then
	exit 0
fi

if [ -x "./node_modules/.bin/cz" ]; then
	exec < /dev/tty && ./node_modules/.bin/cz --hook || true
fi

exit 0
